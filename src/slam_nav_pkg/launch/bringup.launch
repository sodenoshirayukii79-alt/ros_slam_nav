<launch>

  <!-- ========== 顶层参数 ========== -->
  <arg name="mode"         default="slam"/>
  <arg name="use_sim"      default="true"/>

  <arg name="hw_bringup_file"
       default="$(find wpb_home_bringup)/launch/normal.launch"/>

  <arg name="rviz_config" default="AUTO"/>
  <arg name="add_rviz" default="true"/>

  <arg name="map_file"
       default="$(find slam_nav_pkg)/maps/map.yaml"/>

  <arg name="start_keyboard_teleop" default="true"/>

  <!-- ========== 实体机 ========== -->
  <group unless="$(arg use_sim)">
    <param name="/use_sim_time" value="false"/>
    <include file="$(arg hw_bringup_file)"/>
  </group>

  <!-- ========== 仿真 ========== -->
  <group if="$(arg use_sim)">

    <param name="/use_sim_time" value="true"/>

    <include file="$(find wpr_simulation)/launch/wpb_stage_robocup.launch"/>

    <!-- slam模式：键盘直接控制 -->
    <group if="$(eval arg('start_keyboard_teleop') and arg('mode') == 'slam')">
      <node pkg="wpr_simulation"
            type="keyboard_vel_ctrl"
            name="keyboard_vel_ctrl"
            output="screen">
        <remap from="cmd_vel" to="/cmd_vel"/>
      </node>
    </group>

    <!-- nav模式：键盘进入行为层 -->
    <group if="$(eval arg('start_keyboard_teleop') and arg('mode') == 'nav')">
      <node pkg="wpr_simulation"
            type="keyboard_vel_ctrl"
            name="keyboard_vel_ctrl"
            output="screen">
        <remap from="cmd_vel" to="/cmd_vel_teleop"/>
      </node>
    </group>

  </group>

  <!-- ========== SLAM ========== -->
  <group if="$(eval arg('mode') == 'slam')">
    <include file="$(find slam_nav_pkg)/launch/gmapping.launch"/>
  </group>

  <!-- ========== NAV ========== -->
  <group if="$(eval arg('mode') == 'nav')">

    <include file="$(find slam_nav_pkg)/launch/nav.launch">
      <arg name="map_file" value="$(arg map_file)"/>
    </include>

    <!-- Scan Processor -->
    <node pkg="slam_nav_pkg"
          type="scan_processor.py"
          name="scan_processor"
          output="screen">
      <rosparam file="$(find slam_nav_pkg)/config/scan.yaml"
                command="load"/>
    </node>

    <!-- Behavior Layer -->
    <node pkg="slam_nav_pkg"
          type="behavior_layer.py"
          name="behavior_layer"
          output="screen">
      <rosparam file="$(find slam_nav_pkg)/config/behavior.yaml"
                command="load"/>
    </node>

    <!-- Decision Node -->
    <node pkg="slam_nav_pkg"
          type="decision_node.py"
          name="decision_node"
          output="screen">
      <rosparam file="$(find slam_nav_pkg)/config/decision.yaml"
                command="load"/>
    </node>

  </group>

  <!-- ========== RViz ========== -->
  <group if="$(arg add_rviz)">

    <group if="$(eval arg('rviz_config') != 'AUTO')">
      <node pkg="rviz"
            type="rviz"
            name="rviz"
            args="-d $(arg rviz_config)"
            output="screen"/>
    </group>

    <group if="$(eval arg('rviz_config') == 'AUTO' and arg('mode') == 'slam')">
      <node pkg="rviz"
            type="rviz"
            name="rviz"
            args="-d $(find slam_nav_pkg)/config/rviz/gmapping.rviz"
            output="screen"/>
    </group>

    <group if="$(eval arg('rviz_config') == 'AUTO' and arg('mode') == 'nav')">
      <node pkg="rviz"
            type="rviz"
            name="rviz"
            args="-d $(find slam_nav_pkg)/config/rviz/map_tool.rviz"
            output="screen"/>
    </group>

  </group>

</launch>